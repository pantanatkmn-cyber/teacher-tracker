# คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจริง

# Connection string จาก Neon (Dashboard > Connection Details)
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require"

# คีย์ลับสำหรับเข้ารหัส session (สุ่มอย่างน้อย 32 ตัวอักษร)
# สร้างได้ด้วย: openssl rand -base64 32
AUTH_SECRET="เปลี่ยนเป็นคีย์ลับยาวอย่างน้อย32ตัวอักษร"
